# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# URL of your React frontend (used for CORS + OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ── Strava OAuth ──────────────────────────────────────────────────────────────
# Register your app at https://www.strava.com/settings/api
# Set the "Authorization Callback Domain" to: localhost
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:8080/api/auth/strava/callback

# ── WHOOP OAuth ───────────────────────────────────────────────────────────────
# Register your app at https://developer.whoop.com
# Set the redirect URI below in your WHOOP app settings
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=http://localhost:8080/api/auth/whoop/callback
