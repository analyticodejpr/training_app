# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# URL of your React frontend (used for CORS + OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ── Strava OAuth ──────────────────────────────────────────────────────────────
# Register your app at https://www.strava.com/settings/api
# Set the "Authorization Callback Domain" to: localhost
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:8080/api/auth/strava/callback

# ── WHOOP OAuth ───────────────────────────────────────────────────────────────
# Register your app at https://developer.whoop.com
# Set the redirect URI below in your WHOOP app settings
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=http://localhost:8080/api/auth/whoop/callback

# ── Webhooks ─────────────────────────────────────────────────────────────────
# A secret string you choose — passed as verify_token when registering the Strava
# webhook subscription. Must match the value you use in POST /api/v3/push_subscriptions.
STRAVA_WEBHOOK_VERIFY_TOKEN=choose_any_random_string_here

# Optional shared secret for WHOOP webhook HMAC-SHA256 signature verification.
# If set, requests with an invalid X-Whoop-Signature header are rejected.
# Configure this when registering your WHOOP webhook subscription.
WHOOP_WEBHOOK_SECRET=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and anon/publishable key — safe to use server-side with RLS.
# Find these at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key_here
# Secret key — bypasses RLS for server-side writes (keep secret, never expose to client).
# New projects use the sb_secret_... format; legacy projects use a JWT service role key.
# Find at: Supabase Dashboard → Project Settings → API → Secret key
# Required for the Strava import endpoint to write to provider_connections, source_records, activities.
SUPABASE_SECRET_KEY=sb_secret_your_key_here
